---
const userEmail = Astro.cookies.get("userEmail")
---

<header
    class="flex justify-between items-center px-24 py-12 max-sm:px-5 max-sm:py-10 max-w-7xl justify-self-center w-full"
>
    <a href="/" class="flex gap-x-2 items-center">
        <p class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">home</p>
    </a>
    <a href="/" class="flex gap-x-2 items-center">
        <p class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">about</p>
    </a>
    <a href="/blog" class="flex gap-x-2 items-center">
        <p class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">blog</p>
    </a>

    {
        userEmail?.value ? (
            <a
                href="/logout"
                class="bg-teal-900 text-white py-3 px-6 rounded-xl text-xl"
            >
                Logout
            </a>
        ) : (
            <a
                href="/login"
                class="bg-teal-900 text-white py-3 px-6 rounded-xl text-xl"
            >
                Login
            </a>
        )
    }
</header>